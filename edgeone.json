{
  "name": "tools120-media-recorder",
  "nodeVersion": "20.18.0",
  "installCommand": "npm install && npm install --prefix client --include=optional && node scripts/ensure-tailwind-native.mjs",
  "buildCommand": "bash scripts/edgeone-build.sh",
  "outputDirectory": "./client/out",
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    }
  ],
  "cloudFunctions": {
    "nodejs": {
      "externalNodeModules": ["express", "cors", "multer"],
      "maxDuration": 60
    }
  }
}
