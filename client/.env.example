# 复制为 client/.env.local（本地开发，访问 http://127.0.0.1:5173）
# Next.js 读取 NEXT_PUBLIC_*（会打进前端静态包）
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8787

# MiniMax：只在项目根目录 .env 配置 MINIMAX_API_KEY / MINIMAX_API_BASE_URL
# npm run dev 或 start.ps1 会自动同步到本文件，无需在此填写

# 可选，完整上传地址（与 API_BASE 二选一即可）
# NEXT_PUBLIC_UPLOAD_ENDPOINT=http://127.0.0.1:8787/api/audio
