# 复制为 client/.env.local（本地开发，访问 http://127.0.0.1:5173）
# Next.js 构建/运行读取 NEXT_PUBLIC_*（会打进前端静态包）
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8787
# MiniMax API（文字转视频用，获取地址：https://platform.minimaxi.com）
NEXT_PUBLIC_MINIMAX_API_KEY=your_api_key_here
NEXT_PUBLIC_MINIMAX_API_BASE_URL=https://api.minimaxi.com
# 可选，完整上传地址（与 API_BASE 二选一即可）
# NEXT_PUBLIC_UPLOAD_ENDPOINT=http://127.0.0.1:8787/api/audio
