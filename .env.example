# start.ps1 / start.bat 首次启动时会复制为 .env（API 服务用）
APP_HOST=127.0.0.1
APP_PORT=8787
APP_TIMEZONE=Asia/Shanghai
CLIENT_HOST=127.0.0.1
CLIENT_PORT=5173
CLIENT_ORIGIN=http://127.0.0.1:5173
UPLOAD_DIR=output/audio
MAX_AUDIO_MB=25
# 知识问答会话（跨浏览器共享，相对项目根目录）
# CHAT_SESSIONS_PATH=output/chat/knowledge-sessions.json

# MiniMax API（视频/图片/知识问答；获取地址：https://platform.minimaxi.com）
# 仅此文件维护密钥；API 服务读取后代理给所有浏览器，无需在各浏览器「设置」里重复填写
MINIMAX_API_KEY=your_api_key_here
# 不要带 /v1，代码会自动拼接 /v1/video_generation
MINIMAX_API_BASE_URL=https://api.minimaxi.com

# 前端 API 地址（npm run dev 会同步到 client/.env.local；线上在 EdgeOne 构建环境变量里配置）
# 与站点同源时填站点根地址，例如 https://tools120-media-recorder.edgeone.cool
# 预览域名（*-xxx.edgeone.cool）打开时，前端会自动请求「当前页同源」/api/*，勿依赖跨域访问正式域名
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8787
# EdgeOne 侧栏页签跨冷启动持久化：控制台 KV Storage 绑定命名空间，变量名 ui_state_kv（见 cloud-functions/api/ui-state.js）
